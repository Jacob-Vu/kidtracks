{
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ],
    "hosting": [
        {
            "target": "production",
            "public": "dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ],
            "headers": [
                {
                    "source": "**/*.@(js|css|woff2)",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "max-age=31536000, immutable"
                        }
                    ]
                },
                {
                    "source": "**",
                    "headers": [
                        {
                            "key": "Cross-Origin-Opener-Policy",
                            "value": "same-origin-allow-popups"
                        },
                        {
                            "key": "X-Content-Type-Options",
                            "value": "nosniff"
                        }
                    ]
                }
            ]
        },
        {
            "target": "development",
            "public": "dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ],
            "headers": [
                {
                    "source": "**/*.@(js|css|woff2)",
                    "headers": [
                        {
                            "key": "Cache-Control",
                            "value": "max-age=31536000, immutable"
                        }
                    ]
                },
                {
                    "source": "**",
                    "headers": [
                        {
                            "key": "Cross-Origin-Opener-Policy",
                            "value": "same-origin-allow-popups"
                        },
                        {
                            "key": "X-Content-Type-Options",
                            "value": "nosniff"
                        }
                    ]
                }
            ]
        }
    ]
}
